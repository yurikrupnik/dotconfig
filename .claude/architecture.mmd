graph TB
    subgraph "dotconfig Repository"
        subgraph "Rust Binaries"
            CLI[dotconfig CLI<br/>src/main.rs]
            OPR[operator<br/>src/operator.rs]
        end

        subgraph "KCL Modules"
            MANAGER[manager<br/>scripts/kcl/manager]
            STAM[stam v0.0.7<br/>scripts/kcl/stam]

            MANAGER -->|depends on| STAM
            MANAGER -->|uses| ES[external-secrets]
            MANAGER -->|uses| K8S[k8s 1.32.4]
            MANAGER -->|uses| CP[crossplane]
            STAM -->|uses| K8S
            STAM -->|uses| ES
        end

        subgraph "Nu Scripts"
            INDEX[index.nu<br/>Main Entry]
            LOCALDEV[local-dev/<br/>cluster, dotenv, grafana]
            SETUP[setup-local-machine/]
            SHARED[shared/]

            INDEX --> LOCALDEV
            INDEX --> SHARED
        end

        subgraph "Dev Tools"
            JUST[justfile]
            DOCKER[docker-compose.dev.yml]
            TILT[Tiltfile]
            CARGO[Cargo.toml]
        end
    end

    subgraph "External Dependencies"
        OCI[OCI Registry<br/>docker.io/yurikrupnik]
        K8SCLUSTER[Kubernetes Cluster]
    end

    CLI -->|manages| K8SCLUSTER
    OPR -->|watches| K8SCLUSTER
    STAM -->|published to| OCI
    MANAGER -->|pulls from| OCI
    JUST -->|orchestrates| CLI
    JUST -->|orchestrates| INDEX

    style MANAGER fill:#e1f5ff
    style STAM fill:#e1f5ff
    style CLI fill:#ffe1e1
    style OPR fill:#ffe1e1
    style INDEX fill:#e1ffe1

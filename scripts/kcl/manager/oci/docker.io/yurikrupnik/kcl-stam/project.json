{
  "name": "stam",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "scripts/kcl/stam",
//  test:
//  kcl test ./...
//  run:
//  kcl run main.k
//  lint:
//  kcl lint main.k
//  fmt:
//  kcl fmt ./...
//  doc:
//  kcl doc generate
  "targets": {
    "kcl-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kcl test ./...",
        "cwd": "scripts/kcl/stam"
      }
    },
    "kcl-fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kcl fmt ./...",
        "cwd": "scripts/kcl/stam"
      }
    },
    "kcl-serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["kcl run main.k"],
        "parallel": true,
        "readyWhen": "test",
        "cwd": "scripts/kcl/stam",
        "color": true,
        "forwardAllArgs": true,
        "tty": true,
        "env": {
          "lol": "lola"
        }
      }
    },
    "kcl-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kcl lint main.k",
        "cwd": "scripts/kcl/stam"
      }
    },
    "kcl-doc": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kcl doc generate",
        "args": ["--target","../"],
        "cwd": "scripts/kcl/stam"
      }
    }
  },
  "tags": []
}

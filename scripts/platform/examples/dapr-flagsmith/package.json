{
  "name": "dapr-flagsmith-example",
  "version": "1.0.0",
  "type": "module",
  "description": "Dapr + Flagsmith feature flags integration example",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "dapr": "dapr run --app-id feature-flags --app-port 3000 --dapr-http-port 3500 --components-path ./components -- npm start",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@dapr/dapr": "^3.0.0",
    "@openfeature/server-sdk": "^1.6.3",
    "@openfeature/flagsmith-provider": "^0.1.0",
    "flagsmith-nodejs": "^3.0.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0"
  }
}

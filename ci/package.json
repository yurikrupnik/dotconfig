{
  "name": "dotconfig-ci",
  "version": "0.2.0",
  "description": "Dagger CI pipeline using Daggerverse modules",
  "scripts": {
    "build": "dagger call build --source=..",
    "test": "dagger call test --source=..",
    "lint": "dagger call lint --source=..",
    "check": "dagger call check --source=..",
    "container": "dagger call container --source=.. --binary=platform_operator",
    "containers": "dagger call containers --source=..",
    "all": "dagger call all --source=..",
    "publish": "dagger call publish --source=.. --registry=${REGISTRY:-ghcr.io/yurikrupnik}",
    "dev": "dagger call dev --source=.. terminal",
    "dagger:develop": "dagger develop",
    "dagger:functions": "dagger functions"
  }
}
